# Plain WireGuard config for the secondary/fallback VPS
# This path supports a dedicated fallback ingress host.

[Interface]
Address = 10.71.0.1/24
ListenPort = 51820
PrivateKey = <SECONDARY_VPS_PRIVATE_KEY>
SaveConfig = false

# Enable forwarding on the VPS host itself:
#   sysctl -w net.ipv4.ip_forward=1

[Peer]
PublicKey = <HOME_GATEWAY_PUBLIC_KEY>
PresharedKey = <FALLBACK_PRESHARED_KEY>
AllowedIPs = 10.71.0.2/32, 192.168.50.0/24
PersistentKeepalive = 25
