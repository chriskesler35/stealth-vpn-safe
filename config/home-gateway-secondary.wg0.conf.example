# Home gateway config for the secondary/fallback VPS path
# Replace placeholder keys before use.

[Interface]
Address = 10.71.0.2/32
PrivateKey = <HOME_GATEWAY_PRIVATE_KEY>
ListenPort = 51821

# Enable forwarding on the home gateway host itself:
#   sysctl -w net.ipv4.ip_forward=1
#   sysctl -w net.ipv6.conf.all.forwarding=1

[Peer]
PublicKey = <SECONDARY_VPS_PUBLIC_KEY>
PresharedKey = <FALLBACK_PRESHARED_KEY>
Endpoint = fallback.example.com:51820
AllowedIPs = 10.71.0.0/24
PersistentKeepalive = 25
