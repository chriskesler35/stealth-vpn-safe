# Public DNS name for the primary VPS relay
PUBLIC_HOST=vpn.example.com

# Public DNS name for the secondary/fallback VPS
FALLBACK_HOST=fallback.example.com

# Email used by Caddy for ACME/Let's Encrypt
ACME_EMAIL=admin@example.com

# Password hash for wg-easy UI
# Generate with: docker run --rm ghcr.io/wg-easy/wg-easy wgpw 'your-password'
WG_UI_PASSWORD_HASH=

# Public UDP port for the primary WireGuard relay
WG_PORT=51820

# Primary WireGuard overlay network
WG_DEFAULT_ADDRESS=10.70.0.x
WG_DEFAULT_DNS=10.70.0.1

# Secondary/fallback overlay network
FALLBACK_WG_PORT=51820
FALLBACK_WG_SERVER_ADDRESS=10.71.0.1/24
FALLBACK_HOME_GATEWAY_ADDRESS=10.71.0.2/32
FALLBACK_CLIENT_ADDRESS=10.71.0.10/32
FALLBACK_CLIENT_DNS=10.71.0.1

# Public TCP port for the OpenVPN fallback
FALLBACK_OPENVPN_PORT=443

# Home LAN reachable through the home gateway peer
HOME_LAN_CIDR=192.168.50.0/24

# Optional published app through the tunnel
HOME_ASSISTANT_UPSTREAM=10.70.0.2:8123
